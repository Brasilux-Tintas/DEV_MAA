     aAcsUsu := Array(Len(aUsers) + 1, Len(aVetAcs)+1)
     For _nY := 1 To Len(aUsers)
         aAcsUsu[ _nY + 1 ][ 1 ] := Alltrim(aUsers[_nY][1][1])+" - "+Alltrim(aUsers[_nY][1][2])
     Next
     For _nY := 1 To Len(aVetAcs)
         aAcsUsu[ 1 ][ _nY + 1 ] := Alltrim(aVetAcs[_nY])
     Next
     aAcsUsu[1][1] := '\'
     For _nY := 1 To Len(aUsers)
         _cAcess := aUsers[_nY][2][5]
         For _nX := 1 To Len(aVetAcs)
             aAcsUsu[ _nY + 1 ][ _nX + 1 ] := SubStr(_cAcess, _nX, 1)
         Next
     Next
Return(aAcsUsu)