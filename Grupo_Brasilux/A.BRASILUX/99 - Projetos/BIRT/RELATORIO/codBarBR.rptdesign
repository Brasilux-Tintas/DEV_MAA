                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT   B1_COD,B1_DESC,
CASE WHEN B1_MSBLQL = '1' THEN 'EM DESUSO' WHEN (B1_VEND = 'N') THEN 'NAO VENDIDO' ELSE RTRIM(B1_CODBAR)+dbo.DigVer(B1_CODBAR) END AS CODBARRA 
FROM SB1010
WHERE (D_E_L_E_T_ = '') AND (LEN(B1_CODBAR) = 12) AND (B1_COD  = ?)  AND B1_FILIAL = '010101']]></xml-property>
            <xml-property name="designerValues"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
