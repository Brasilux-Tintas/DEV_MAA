User Function PagNos()
     If SubStr(SE2->E2_CODBAR, 01, 3) != "237"
        _RETNOS := "000000000"
     Else
        _RETNOS := SubStr(SE2->E2_CODBAR, 28, 9)
     EndIf
Return(_RETNOS)