*/
User Function Pagtip()
     Local _RETTIP
     u_zcfga01( 'PAGTIP' ) //LGS#2021202 - Grava鈬o de log de utiliza鈬o da rotina
     If SubStr(SE2->E2_TIPO, 1, 2) == "FT"
        _RETTIP := "02"
     ElseIf SubStr(SE2->E2_TIPO, 1, 2) == "NF"
            _RETTIP := "03"
     ElseIf SubStr(SE2->E2_TIPO, 1, 2) == "DP"
            _RETTIP := "04"
     Else
        _RETTIP := "05"
     Endif
Return(_RETTIP)        
