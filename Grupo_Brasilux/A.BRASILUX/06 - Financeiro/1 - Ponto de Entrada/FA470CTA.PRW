User Function FA470CTA()
     Local _cBanco   := mv_par03
     Local _cAgencia := mv_par04
     Local _cConta   := mv_par05
     Local _aRet     := {}
Local  _cGrpEmp := ALLTRIM(FWGrpCompany())

     If _cGrpEmp <> '11' //Empresas que n縊 s縊 do grupo 11(Tecpolpa).
        _aRet := {_cBanco, _cAgencia, _cConta}
     Endif
Return(_aRet)
