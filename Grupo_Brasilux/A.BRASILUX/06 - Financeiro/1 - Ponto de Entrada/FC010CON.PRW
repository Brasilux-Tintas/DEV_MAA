//30/09/2019 - Lu﨎 Gustavo - Adequa鈬o para release 12.1.25
User Function FC010CON()
     Local cEmprs := ""
     Local nArea  := Alias() 
     Local cQuery := ""
Local  _cGrpEmp := ALLTRIM(FWGrpCompany())

     If _cGrpEmp == '01' //Empresas que s縊 do grupo 01-BRASILUX.
        cQuery += "SELECT TOP 1 '01' AS EMPRESA "
        cQuery += "FROM "+RetSqlName("SE1")+" SE1 WITH (NOLOCK) "
        cQuery += "WHERE (SE1.E1_CLIENTE = '"+SA1->A1_COD+"') "
        cQuery += "  AND (SE1.E1_NATUREZ = '801004') "
        cQuery += "  AND (SE1.D_E_L_E_T_ <> '*') "
        cQuery += "UNION ALL "
        cQuery += "SELECT TOP 1 '02' AS EMPRESA "
        cQuery += "FROM SE1020 SE1 WITH (NOLOCK) "
        cQuery += "WHERE (SE1.E1_CLIENTE = '"+SA1->A1_COD+"') "
        cQuery += "  AND (SE1.E1_NATUREZ = '801004') "
        cQuery += "  AND (SE1.D_E_L_E_T_ <> '*') "
        cQuery += "UNION ALL "
        cQuery += "SELECT TOP 1 '03' AS EMPRESA "
        cQuery += "FROM SE1030 SE1 WITH (NOLOCK) "
        cQuery += "WHERE (SE1.E1_CLIENTE = '"+SA1->A1_COD+"') "
        cQuery += "  AND (SE1.E1_NATUREZ = '801004') "
        cQuery += "  AND (SE1.D_E_L_E_T_ <> '*') "
        cQuery += "ORDER BY EMPRESA "
        TCQUERY cQuery ALIAS "TMPLP" NEW

        DbSelectArea("TMPLP")
        DbGoTop()
        cEmprs := ""
        While !Eof()
              cEmprs += TMPLP->EMPRESA+","
              DbSkip()
        Enddo

        If !Empty(cEmprs)
           cEmprs := SubStr(cEmprs, 1, Len(cEmprs) - 1)
           MsgBox("Cliente POSSUI t咜ulo(s) em LUCROS E PERDAS na(s) empresa(s) "+cEmprs+"!", "*** AVISO ***", "INFO")
        Else
           MsgBox("Cliente NﾃO POSSUI t咜ulo(s) em LUCROS E PERDAS!", "*** AVISO ***", "INFO")
        Endif
        DbSelectArea("TMPLP")
        DbCloseArea("TMPLP")
        DbSelectArea(nArea)
     Endif
Return(.t.)
