User Function BRFAT104()
     Local cVldAlt   := ".T." // Validacao para permitir a alteracao. Pode-se utilizar ExecBlock.
     Local cVldExc   := ".T." // Validacao para permitir a exclusao. Pode-se utilizar ExecBlock.
     Private cString := "Z17"

     cVldAlt := 'ExecBlock("FAT104_1", .F., .F.)'       
     cVldExc := 'ExecBlock("FAT104_2", .F., .F.)'
     u_zcfga01( 'BRFAT104' ) //LGS#2021201 - Grava鈬o de log de utiliza鈬o da rotina
     DbSelectArea("Z17")
     DbSetOrder(1)

     AxCadastro(cString, "NCMs Isentos de ST", cVldExc, cVldAlt)
Return

User Function FAT104_1()
Return(.t.)

User Function FAT104_2()

Return(.t.)
