User Function ZFATP03 (aCabec,aItens,nOpcX)
Local cRet := .F.
Private lMsErroAuto    := .F.

   // nOpcX
   // 3 inclusŃo
   // 4 AlterańŃo
   MSExecAuto({|a, b, c, d| MATA410(a, b, c, d)}, aCabec, aItens, nOpcX, .F.)    
   If !lMsErroAuto
      cRet := .T. // Sucesso
   Else
      cRet := .F. // Erro
      MostraErro()
   EndIf

return(cRet)
