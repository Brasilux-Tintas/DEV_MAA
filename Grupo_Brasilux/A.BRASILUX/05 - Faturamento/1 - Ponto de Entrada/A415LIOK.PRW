//25/09/2019 - Luэs Gustavo - Adequaчуo para release 12.1.25
User Function A415LIOK()
     Local _cArea    := alias()
     Local aAreaTMP1
     Local cCodPro   := ""
     Local lRet      := .t.

     If FWCodEmp() <> '11' //Empresas que nуo sуo do grupo 11(Tecpolpa).
        If !TMP1->CK_FLAG //Verifica se nуo щ registro deletado         
           cCodPro := TMP1->CK_PRODUTO
           dbSelectArea("TMP1")
           aAreaTMP1 := GetArea()
           dbGotop()
           While ( !Eof() )
                 If !TMP1->CK_FLAG .And. (TMP1->(RecNo()) <> aAreaTMP1[3]) .And. (TMP1->CK_PRODUTO == cCodPro)
                    lRet = .f.
                    exit 
                 Endif 
                 dbSelectArea("TMP1")
		         dbSkip()
           EndDo
           RestArea(aAreaTMP1)
        Endif
        If !lRet
           MsgBox("Existe item em DUPLICIDADE!", "Atenчуo...", "ALERT")
        Endif 
        If !empty( _cArea )
           DbSelectArea( _cArea )
        Endif 
     Endif
Return(lRet)
