//25/09/2019 - Lu﨎 Gustavo - Adequa鈬o para release 12.1.25
User Function MTA456I()
     Local lBloqueado
     Local cArea := Alias()

     If alltrim(FWGrpCompany()) == '01' //Empresas que n縊 s縊 do grupo 11(Tecpolpa).
        DbSelectArea("SC9")
        lBloqueado = U_EstaBloqueado("SC9", RecNo())
        If !lBloqueado
           RecLock("SC9", .F.)
        Endif     

        SC9->C9_DTLCRED := dDataBase                //Grava data de Liberacao do Credito/Estoque
        SC9->C9_LIBPOR  := rtrim(cUserName)  //Gravar nome de quem liberou
        If !lBloqueado 	
		   MsUnLock()
        Endif 
        if !empty(cArea) 
           DbSelectArea(cArea)
        endif 
     Endif
Return(.t.)
