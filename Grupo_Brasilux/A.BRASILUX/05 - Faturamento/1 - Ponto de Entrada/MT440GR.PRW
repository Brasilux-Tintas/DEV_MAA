User Function MT440GR()
     Local lRet := .t.
     u_zcfga01( 'MT440GR' ) //LGS#2021201 - Gravaчуo de log de utilizaчуo da rotina
     If FWCodEmp() <> '11' //Empresas que nуo sуo do grupo 11(Tecpolpa).
        If SC5->C5_NAOCONF == "S"
           MsgBox("Atencao! Pedido NAO RESPEITA as Politicas Comerciais Para Revenda! Liberacao Nao Permitida!", "ATEN╟├O", "STOP")
           lRet := .f.
        Endif
     Endif 
Return(lRet)
