User Function BRFAT064()
     Local nArea    := Alias()
     Local nRecno   := Recno()
     Local nIndex   := IndexOrd()
     Local cCliente
     Local cMun     := Space(30)

     DbSelectArea("SF2")
     DbSetOrder(1)
     DbSeek(xfilial("SF2")+M->ZD_NOTA, .F.)

     DbSelectArea("SA1")
     DbSetorder(1)
     DbSeek(xfilial("SA1")+SF2->F2_CLIENTE, .F.)

     cMun := SubStr(SA1->A1_MUN, 1, 30)

     DbSelectArea(nArea)
     DbSetOrder(nIndex)
     DbGoto(nRecno)
Return(cMun)