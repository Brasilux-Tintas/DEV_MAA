//30/09/2019 - Luэs Gustavo - Adequaчуo para release 12.1.25
User Function MTA200() 
     Local cAux := oTree:GetCargo()
     Local lRet := .t.

     If FWCodEmp() <> '11' //Empresas que nуo sуo do grupo 11(Tecpolpa).  
        If (Val(SubStr(cAux, 43, 9)) != 1) .and. (Val(SubStr(cAux, 43, 9)) != 0)
           If (Paramixb == "I")
              MsgBox("Inclusao nуo permitida nesse nэvel!", "Atenчуo...", "STOP")
              lRet := .f.
           Else
              If Substr(cAux, 1, 15) != cCodAtual
                 MsgBox("Ediчуo de produto nуo permitida nesse nэvel!", "Atenчуo...", "STOP")
                 lRet := .f.
              Endif
           Endif
        Endif
     Endif   
Return(lRet)
