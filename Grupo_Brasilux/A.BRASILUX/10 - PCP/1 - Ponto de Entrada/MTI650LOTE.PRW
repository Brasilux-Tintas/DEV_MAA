#Include 'TOTVS.ch'

/*/{Protheus.doc} MTI650LOTE
//TODO Complementa informaçőes do XML para integraçăo com o PCFactory.
//30/09/2019 - Luís Gustavo - Adequaçăo para release 12.1.25
@author gustavosouza
@since 01/01/2019
@version 1.0
@return ${return}, ${return_description}

@type function
/*/
User Function MTI650LOTE()
     Local _cPont := PARAMIXB //Ponteiro para recuperar as informaçőes da SC2. Utilizaçăo: &(cPont+"(C2_QUANT)")
     Local _cLote := ""
     Local _aArea := GetArea()

     If FWCodEmp() <> '11' //Empresas que năo săo do grupo 11(Tecpolpa).
        _cLote := &(_cPont+"(C2_LOTE)")
     Endif
     RestArea(_aArea)
Return _cLote