User Function BRPCP017()
Local lFiltro  := .f.
Local cAuxUser := Alltrim(Upper(cUsername))
Local  _cGrpEmp := ALLTRIM(FWGrpCompany())
     u_zcfga01( 'BRPCP017' ) //LGS#2021201 - Grava鈬o de log de utiliza鈬o da rotina
IF _cGrpEmp == "01" //Apenas empresas do Grupo 01 (TecPolpa e UnionSur n縊 entram)
   If !(cAuxUser $ "CAIO_KELLY_MARQUINHOS")
        lFiltro := .t.
        DbSelectArea("SG1")
        SET FILTER TO (Len(Alltrim(G1_COD)) # 6) .and. (SubStr(G1_COD, 1, 2) # "BM")
   Endif
ENDIF 
MATA200() //Estrutura dos produtos
If lFiltro
   DbSelectArea("SG1")
   SET FILTER TO
Endif
Return
