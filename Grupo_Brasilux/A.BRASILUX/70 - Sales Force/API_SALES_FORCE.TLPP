class salesforce from fwAdapterBaseV2

	public method new() constructor

 	/* API que retorna o saldo do produto */
    @post('/salesforce/saldo')
	public method saldo() as logical

    @post('/salesforce/tabela')
	public method tabela() as logical

    @post('/salesforce/produtos')
	public method produtos() as logical

    @post('/salesforce/reservar')
	public method reserva() as logical

    @get('/salesforce/listareserva')
	public method listareserva() as logical

    @get('/salesforce/listarclientes')
	public method listarclientes() as logical

    @get('/salesforce/listarpagamento')
	public method listarpagamento() as logical
    
end class

method new() class salesforce; return self


/* API que retorna o saldo do produto */
method saldo() class salesforce

	Local jBodyReq  as json
    Local cPagIni   as numeric
    Local cCodTab   as character
	
    Local oError         as object

    Private lMsErroAuto as logical
    Private err as object
   
    Try //inicio do bloco de c¾digo contendo o controle de erro
    
            jBodyReq := jsonObject():new()
            // retornar o body da requisińŃo HTTP
            jBodyReq:fromJson(oRest:getBodyRequest())
        
            // retornar os parŌmetros informados na requisińŃo via URI (query param)
            jQueryStr := oRest:getQueryRequest()


            If Empty(jBodyReq["codigotabelapreco"])        
                jResp           := jsonObject():new()
                jResp['Requerido']  := 'Necessßrio informar a variavel codigotabelapreco !'
                oRest:setStatusCode(402)
                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            Else
                cCodTab := jBodyReq["codigotabelapreco"]
            EndIf


            If Empty(jBodyReq["deposito"])
                
                jResp           := jsonObject():new()
                jResp['Requerido']  := 'Necessßrio informar deposito !'
                oRest:setStatusCode(402)
                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            else
                
                If ( UPPER(jBodyReq["deposito"]) == "ARARAQUARA")
                    cDeposito := "A3"                                                                                       
                Elseif ( UPPER(jBodyReq["deposito"]) == "GUARULHOS")
                    cDeposito := "G3"
                endif
                
            EndIf       

    
   
	
            If Empty(jBodyReq["empresa"])
                jResp           := jsonObject():new()
                jResp['Requerido']  := 'Necessßrio informar a variavel empresa (Dissoltex ou Brasilux) !'
                oRest:setStatusCode(402)
                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            else

                If ( UPPER(jBodyReq["empresa"]) == "DISSOLTEX")
                    cFil := "060101"
                Elseif ( UPPER(jBodyReq["empresa"]) == "BRASILUX") 
                    cFil := "010101"
                else
                    
                    jResp           := jsonObject():new()
                    jResp['Requerido']  := 'Necessßrio informar a variavel empresa (Dissoltex ou Brasilux) !'
                    oRest:setStatusCode(402)
                    oRest:appendKeyHeaderResponse("Content-Type","application/json")
                    oRest:setResponse(jResp:toJson())
                    return .T.

                EndIF

            EndIf 

            // Seta Empresa 
            RpcSetEnv("01",cFil,"","","","",{"DA0","DA1","SB1","SB2"})

            cSQL := "SELECT "                                                                       + CRLF
            
            If cDeposito == "A3"
                cSQL += "  'ARARAQUARA' DEPOSITO,  "                                                 + CRLF
            else
                cSQL += "  'GUARULHOS' DEPOSITO,  "                                                 + CRLF
            EndIF
            
            /*cSQL += "CASE  "                                                                        + CRLF
            cSQL += "        WHEN DA0_X_DP = 'A' THEN 'ARARAQUARA' "                                + CRLF
            cSQL += "        WHEN DA0_X_DP = 'G' THEN 'GUARULHOS'  "                                + CRLF
            cSQL += "END DEPOSITO, "                                                               + CRLF*/ 


            cSQL += "CASE  "                                                                        + CRLF
            cSQL += "        WHEN B1_MSBLQL = '1' THEN 'Sim' "                                      + CRLF
            cSQL += "        WHEN B1_MSBLQL = '2' THEN 'NŃo'  "                                     + CRLF
            cSQL += "END BLOQUEADO, "                                                               + CRLF

            /*cSQL += "CASE "                                                                         + CRLF
            cSQL += " WHEN DA0_X_DP = 'A' THEN  (SELECT ( ((B2_QATU) - (B2_RESERVA)- (B2_QEMP)- (B2_QACLASS)- (B2_QEMPSA) - (B2_QEMPPRJ)-(B2_QTNP)) + (B2_QNPT) - (B2_QEMPPRE) ) FROM SB2010 WHERE B2_COD = B1_COD AND B2_FILIAL = B1_FILIAL AND B2_LOCAL = 'A3')  " + CRLF
            cSQL += " WHEN DA0_X_DP = 'G' THEN  (SELECT ( ((B2_QATU) - (B2_RESERVA)- (B2_QEMP)- (B2_QACLASS)- (B2_QEMPSA) - (B2_QEMPPRJ)-(B2_QTNP)) + (B2_QNPT) - (B2_QEMPPRE) ) FROM SB2010 WHERE B2_COD = B1_COD AND B2_FILIAL = B1_FILIAL AND B2_LOCAL = 'G3')  " + CRLF
            cSQL += " END saldo, "*/
            
            cSQL += " (SELECT ( ((B2_QATU) - (B2_RESERVA)- (B2_QEMP)- (B2_QACLASS)- (B2_QEMPSA) - (B2_QEMPPRJ)-(B2_QTNP)) + (B2_QNPT) - (B2_QEMPPRE) ) FROM SB2010 WHERE B2_COD = B1_COD AND B2_FILIAL = B1_FILIAL AND B2_LOCAL = '"+cDeposito+"') saldo, "    + CRLF
            
            cSQL += "B1_DESC,DA1_PRCVEN,"                                                           + CRLF
            cSQL += " DA1_CODTAB,DA0_DESCRI,DA1_CODPRO "                                            + CRLF
            cSQL += " FROM "+RetSqlName("DA0")+" DA0 "                                              + CRLF
            cSQL += "INNER JOIN "+RetSqlName("DA1")+" DA1 ON DA1.D_E_L_E_T_ = '' AND DA1_FILIAL = DA0_FILIAL AND DA1_CODTAB = DA0_CODTAB "  + CRLF
            cSQL += "INNER JOIN "+RetSqlName("SB1")+" SB1 ON SB1.D_E_L_E_T_ = '' AND B1_FILIAL = DA0_FILIAL AND B1_COD = DA1_CODPRO "       + CRLF
            cSQL += "WHERE DA0.D_E_L_E_T_ = '' AND DA0_FILIAL = '"+xFilial("DA1")+"' "                                                      + CRLF
            cSQL += "AND DA0_ATIVO = '1'  "                                                                                                 + CRLF
            cSQL += "AND DA0_CODTAB = '"+cCodTab+"' "                                                                                       + CRLF
            cSQL += "AND convert(varchar, getdate(), 112) >= DA0_DATDE   "                                                                  + CRLF
            cSQL += "AND convert(varchar, getdate(), 112) <= DA0_DATATE "                                                                   + CRLF

            If .not. Empty(jBodyReq["produto"])
                cListProd :=   lista_produtos(jBodyReq)
                cSQL            += "AND DA1_CODPRO IN "+cListProd+" "                                                                       + CRLF
            EndIf    

            If .not. Empty(jBodyReq["bloqueado"])
                
                cBloqueado := DecodeUTF8(jBodyReq["bloqueado"], "cp1252")
                cBloqueado := UPPER(cBloqueado) 

                If ( cBloqueado == "N├O") .OR. ( cBloqueado == "NAO")
                    cSQL += "AND B1_MSBLQL <> '1' "                                                                                         + CRLF
                elseif ( cBloqueado == "SIM") 
                    cSQL += "AND B1_MSBLQL = '1' "                                                                                          + CRLF
                EndIF
                
                
            EndIf    

            // Alterado conforme solicitado por Rodrigo 06/12/24
            /*If .not. Empty(jBodyReq["deposito"])

                If ( UPPER(jBodyReq["deposito"]) == "ARARAQUARA")
                    cSQL += "AND DA0_X_DP = 'A' "                                                                                           + CRLF
                Elseif ( UPPER(jBodyReq["deposito"]) == "GUARULHOS")
                    cSQL += "AND DA0_X_DP = 'G' "                                                                                           + CRLF    
                endif
                
            EndIf*/       

            cSQL += " ORDER BY DA1_CODPRO "                                                                                                 + CRLF
            nStatus := TCSqlExec(cSQL)
            // valida consulta SQL e informa erro
            if (nStatus < 0)
                jResp           := jsonObject():new()
                jResp['Erro']  := 'Erro na consulta SQL !'
                
                // Gera Log com erro
                //         cStatus, cRotina          , Funcao    , cPedido, cLog
                U_API_LOGS("A"    , "API_SALES_FORCE", ProcName(), ''     , TCSQLERROR())
                U_EnvMail("[SALES FORCE]["+GetEnvServer()+"][SALDO] - Erro API_SALES_FORCE",TCSQLERROR(),"neliedercorneta@brasilux.com.br","","")
                oRest:setStatusCode(500)
                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            else
                 MemoWrite("\ws_logs\salesforce\saldo\SaldoQuery.txt",cSQL)
                cAliasSQL       := getNextAlias()  
            endif
                 
            dbUseArea(.T.,"TOPCONN",tcGenQry(,,cSQL),cAliasSQL,.T.,.T.)    
            Count To nTotal
            (cAliasSQL)->(DbGoTop())

            /* Busca relańŃo de nomes dos campos */
            aNomes := {}
            aNomes := U_API_NOMES()

            nPage := jQueryStr['page']
            nSize := jQueryStr['pagesize']

            nPage   := if(empty(nPage),1 ,val(nPage))
            nSize   := if(empty(nSize),10,val(nSize))

            nConta := 1
            cLoop := (nPage * nSize)
            
            nPage   := nPage - 1
            
            cPagIni := (nPage*nSize)
            cPagIni := if(cPagIni==0,1,cPagIni)

            jResp             := jsonObject():new()
            jResp['produtos'] := array(0)
            
            If nPage >= 1
                (cAliasSQL)->(dbSkip(cPagIni))
            EndIF

            While .not. (cAliasSQL)->(eof()) .AND. nConta <= nSize 

                jSaldo                       := jsonObject():new()
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "DA1_CODTAB"})==0,1,aScan(aNomes, {|x| x[1] == "DA1_CODTAB"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DA1_CODTAB ))
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "DA0_DESCRI"})==0,1,aScan(aNomes, {|x| x[1] == "DA0_DESCRI"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DA0_DESCRI ))

                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "DA1_CODPRO"})==0,1,aScan(aNomes, {|x| x[1] == "DA1_CODPRO"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DA1_CODPRO ))
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "B1_DESC"})==0,1,aScan(aNomes, {|x| x[1] == "B1_DESC"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(B1_DESC ))
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "PROBLOQUEADO"})==0,1,aScan(aNomes, {|x| x[1] == "PROBLOQUEADO"}))
                
                If (cAliasSQL)->(alltrim(BLOQUEADO )) == "Sim"
                    jSaldo[aNomes[cPos][2]] := .T.
                else
                    jSaldo[aNomes[cPos][2]] := .F.
                EndIF
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "DA1_PRCVEN"})==0,1,aScan(aNomes, {|x| x[1] == "DA1_PRCVEN"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(DA1_PRCVEN)
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "DEPOSITO"})==0,1,aScan(aNomes, {|x| x[1] == "DEPOSITO"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DEPOSITO ))
                
                cPos                    := IIf(aScan(aNomes, {|x| x[1] == "Saldo"})==0,1,aScan(aNomes, {|x| x[1] == "Saldo"}))
                jSaldo[aNomes[cPos][2]] := Val((cAliasSQL)->(alltrim(str(Saldo) )))

                aadd(jResp['produtos'],jSaldo)  
                nConta++
                (cAliasSQL)->(dbSkip())

            End

            If cLoop > nTotal   
                jResp['hasNext'] := .F.
            else
                jResp['hasNext'] := .T.
                jResp['remainingRecords'] := AllTrim(str(nTotal-cLoop))
            Endif    

            (cAliasSQL)->(dbCloseArea())
            
            oRest:appendKeyHeaderResponse("Content-Type","application/json")
            oRest:setResponse(jResp:toJson())

    CATCH oError

		jResp               := jsonObject():new()
        jResp['Erro']  := 'Erro na execuńŃo '+oError:description

        // Gera Log com erro
        //         cStatus, cRotina          , Funcao    , cPedido, cLog
        U_API_LOGS("B"    , "API_SALES_FORCE", ProcName(), ''     , oError:description)
              
        U_EnvMail("[SALES FORCE]["+GetEnvServer()+"][SALDO] - Erro API_SALES_FORCE",oError:description,"neliedercorneta@brasilux.com.br","","")
        
        oRest:setStatusCode(501)
        oRest:appendKeyHeaderResponse("Content-Type","application/json")
        oRest:setResponse(jResp:toJson())
        return .T.

	ENDTRY  


    RpcClearEnv()

return .T.


method tabela() class salesforce

	Local jBodyReq      as json
    
    Local oError         as object

	Private lMsErroAuto as logical

    jBodyReq := jsonObject():new()
    jBodyReq:fromJson(oRest:getBodyRequest())

    
    Try
    
            // valida se campo obrigatorio empresa foi enviado no body
            If Empty(jBodyReq["empresa"])
                jResp           := jsonObject():new()
                jResp['Requerido']  := 'Necessßrio informar a variavel empresa (Dissoltex ou Brasilux) !'
                oRest:setStatusCode(402)
                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            else
                // obrigatorio informar empresas brasilux ou dissoltex
                If ( UPPER(jBodyReq["empresa"]) == "DISSOLTEX")
                    cFil := "060101"
                Elseif ( UPPER(jBodyReq["empresa"]) == "BRASILUX") 
                    cFil := "010101"
                else
                    // caso nŃo seja selecionado nenhuma das empresa informa
                    jResp           := jsonObject():new()
                    jResp['Requerido']  := 'Necessßrio informar a variavel empresa (Dissoltex ou Brasilux) !'
                    oRest:setStatusCode(402)
                    oRest:appendKeyHeaderResponse("Content-Type","application/json")
                    oRest:setResponse(jResp:toJson())
                    return .T.

                EndIF

            EndIf    

            // Seta Empresa 
            RpcSetEnv("01",cFil,"","","","",{"DA0","DA1","SB1","SB2"})

            cSQL := "SELECT " + CRLF 
            cSQL += "CASE   " + CRLF 
            cSQL += "    WHEN DA0_X_DP = 'A' THEN 'ARARAQUARA'  " + CRLF 
            cSQL += "    WHEN DA0_X_DP = 'G' THEN 'GUARULHOS'   " + CRLF 
            cSQL += "    ELSE ''  " + CRLF 
            cSQL += "END DEPOSITO,  " + CRLF 
            cSQL += "DA0_DESCRI,DA0_CODTAB   " + CRLF 
            cSQL += "FROM "+RetSqlName("DA0")+" DA0  " + CRLF 
            cSQL += "WHERE DA0.D_E_L_E_T_ = '' AND DA0_FILIAL = '"+xFilial("DA1")+"'  " + CRLF 
            cSQL += "AND DA0_ATIVO = '1'   " + CRLF 
            //cSQL += "AND DA0_X_DP <> ''  " + CRLF 
            cSQL += "AND convert(varchar, getdate(), 112) >= DA0_DATDE    " + CRLF 
            cSQL += "AND convert(varchar, getdate(), 112) <= DA0_DATATE  " + CRLF 

            

            nStatus := TCSqlExec(cSQL)
            // valida consulta SQL e informa erro
            if (nStatus < 0)
                jResp           := jsonObject():new()
                jResp['Erro']  := 'Erro na consulta SQL !'

                // Gera Log com erro
                //         cStatus, cRotina          , Funcao    , cPedido, cLog
                U_API_LOGS("A"    , "API_SALES_FORCE", ProcName(), ''     , TCSQLERROR())
                U_EnvMail("[SALES FORCE]["+GetEnvServer()+"][TABELA] - Erro API_SALES_FORCE",TCSQLERROR(),"neliedercorneta@brasilux.com.br","","")

                oRest:appendKeyHeaderResponse("Content-Type","application/json")
                oRest:setResponse(jResp:toJson())
                return .T.
            else
                cAliasSQL       := getNextAlias()
                dbUseArea(.T.,"TOPCONN",tcGenQry(,,cSQL),cAliasSQL,.T.,.T.)   
            endif

            

            jResp             := jsonObject():new()
            jResp['tabela']   := array(0)
            
            aNomes := {}
            aNomes := U_API_NOMES()

    

            While .not. (cAliasSQL)->(eof())
                
                jSaldo                       := jsonObject():new()

                cPos := IIf(aScan(aNomes, {|x| x[1] == "DEPOSITO"})==0,1,aScan(aNomes, {|x| x[1] == "DEPOSITO"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DEPOSITO ))

                cPos := IIf(aScan(aNomes, {|x| x[1] == "DA0_DESCRI"})==0,1,aScan(aNomes, {|x| x[1] == "DA0_DESCRI"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DA0_DESCRI ))

                cPos := IIf(aScan(aNomes, {|x| x[1] == "DA0_CODTAB"})==0,1,aScan(aNomes, {|x| x[1] == "DA0_CODTAB"}))
                jSaldo[aNomes[cPos][2]] := (cAliasSQL)->(alltrim(DA0_CODTAB ))
            
                //jBodyReq['hasNext'] := .T.
                aadd(jResp['tabela'],jSaldo)  

                (cAliasSQL)->(dbSkip())

            End

    
            (cAliasSQL)->(dbCloseArea())

    CATCH oError

		jResp               := jsonObject():new()
        jResp['Erro']  := 'Erro na execuńŃo parte 1, '+oError:description

        
        //         cStatus, cRotina          , Funcao    , cPedido, cLog
        U_API_LOGS("B"    , "API_SALES_FORCE", ProcName(), ''     , oError:description)
        U_EnvMail("[SALES FORCE]["+GetEnvServer()+"][TABELA] - Erro API_SALES_FORCE",oError:description,"neliedercorneta@brasilux.com.br","","")
        
        oRest:appendKeyHeaderResponse("Content-Type","application/json")
        oRest:setResponse(jResp:toJson())
        return .T.

	ENDTRY  

    oRest:appendKeyHeaderResponse("Content-Type","application/json")
    oRest:setResponse(jResp:toJson())

    RpcClearEnv()

return .T.



method listareserva() class salesforce
Local nError        as numeric
Local cError        as character

Local jQueryStr     as json
Local jResp         as json

Local cSQL          as character
Local cWhere        as character
Local nSize         as numeric
Local nPage         as numeric
Local cOrder        as character
Local cReserva      as character
Local cSku          as character


	try

		jQueryStr           := oRest:getQueryRequest()

		cReserva            := jQueryStr['reserva']
        cReserva            := jQueryStr['codigoreserva']
        cSku                := jQueryStr['sku']

		cSQL                := "SELECT #QueryFields# FROM " + retSqlName("SC0") + " SC0"
		cSQL                += CRLF + "WHERE #QueryWhere# "

		cWhere              := "D_E_L_E_T_ = ' ' "

		IF .not. empty(cReserva)
			cWhere          += CRLF + "AND C0_XIDSF = '" + cReserva + "' "
		EndIF

        IF .not. empty(cSku)
			cWhere          += CRLF + "AND C0_PRODUTO = '" + cSku + "' "
		EndIF

        nSize               := if(empty(nSize),100,nSize)
		nPage               := if(empty(nPage),1 ,nPage)
        

		_Super:new('GET',.T.)
		::addMapFields('CodigoReserva'  ,'C0_XIDSF'     ,.T.)
		::addMapFields('Sku'            ,'C0_PRODUTO'   ,.T.)
		::addMapFields('Local'          ,'C0_LOCAL'     ,.T.)
		::addMapFields('Quantidade'     ,'C0_QUANT'     ,.T.)
		::addMapFields('Validade'       ,'C0_VALIDA'    ,.T.)
        ::addMapFields('Emissao'        ,'C0_EMISSAO'   ,.T.)

		::setQuery(cSQL)
		::setWhere(cWhere)
		::setPageSize(nSize)
		::setPage(nPage)
		::setOrder(cOrder)

		IF ::execute()
			::fillGetResponse()
            oRest:appendKeyHeaderResponse("Content-Type","application/json") // altera para json
			oRest:setResponse(::getJsonResponse())
		Else

			nError := ::getCode()
			cError := ::getMessage()

			jResp := jsonObject():new()
			jResp['error'] := cError

			oRest:setFault(jResp:toJson())

		EndIF

	catch err

		cError          := err:errorstack

		jResp           := jsonObject():new()
		jResp['error']  := cError

		oRest:setFault(jResp:toJson())

	endtry

	

return .T.


method listarclientes() class salesforce
Local nError        as numeric
Local cError        as character

Local jQueryStr     as json
Local jResp         as json

Local cSQL          as character
Local cWhere        as character
Local nSize         as numeric
Local nPage         as numeric
Local cOrder        as character
Local cID           as character
Local cCGC          as character
Local aNomes        as array


	try

		jQueryStr           := oRest:getQueryRequest()

		cID     := jQueryStr['id']
        cCGC    := jQueryStr['cpf_cnpj']

        nPage   := jQueryStr['page']
        nSize   := jQueryStr['pagesize']

        nPage   := if(empty(nPage),1 ,val(nPage))
        nSize   := if(empty(nSize),100,val(nSize))

		cSQL                := "SELECT #QueryFields# FROM " + retSqlName("SA1") + " SA1"
        cSQL                += CRLF + " LEFT JOIN " + retSqlName("SYA") + " SYA ON SYA.D_E_L_E_T_ = '' AND YA_CODGI = A1_PAIS " 
		cSQL                += CRLF + "WHERE #QueryWhere# "

		cWhere              := " SA1.D_E_L_E_T_ = ' ' "

		IF .not. empty(cID)
			cWhere          += CRLF + "AND A1_COD = '" + cID + "' "
		EndIF

        IF .not. empty(cCGC)
			cWhere          += CRLF + "AND A1_CGC = '" + cCGC + "' "
		EndIF

        
        aNomes := {}
        aNomes := U_API_SX3()

                
		_Super:new('GET',.T.)
		
        cPos := IIf(aScan(aNomes, {|x| x[1] == "A1_FILIAL"})==0,1,aScan(aNomes, {|x| x[1] == "A1_FILIAL"}))
        ::addMapFields(aNomes[cPos][2]  ,'A1_FILIAL'     ,.T.)
		
