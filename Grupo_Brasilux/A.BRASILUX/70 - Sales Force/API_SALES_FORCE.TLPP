        ::addMapFields(aNomes[cPos][2]  ,'A1_PAIS'     ,.T.)*/



        cPos := IIf(aScan(aNomes, {|x| x[1] == "A1_MSBLQL"})==0,1,aScan(aNomes, {|x| x[1] == "A1_MSBLQL"}))        
        ::addMapFields(aNomes[cPos][2]  ,'A1_MSBLQL'     ,.T.)

