//25/09/2019 - Luํs Gustavo - Adequa็ใo para release 12.1.25
User Function MT110GRV()   
     Local _cAlias  := Alias()
     Local aAreaAnt := u_PegaArea({"SZU"})
     u_zcfga01( 'MT110GRV' ) //LGS#2021118 - Grava็ใo de log de utiliza็ใo da rotina
     If alltrim(FWGrpCompany()) <> '11' //Empresas que nใo sใo do grupo 11(Tecpolpa).
        If !Empty(SC1->C1_IDREQUI)
           DbSelectArea("SZU")
           DbSetOrder(1)
           DbSeek(xFilial("SZU")+SC1->C1_IDREQUI, .t.)
           If Found()
              RecLock("SC1", .f.)
                 SC1->C1_SOLICIT := SZU->ZU_SOLICIT
              MsUnLock()
           Endif
        Endif
        U_VoltaArea(aAreaAnt)
        If !EMPTY( _cAlias )
	       DbSelectArea( _cAlias )
        Endif
     Endif 
Return
