#include "rwmake.ch"
#Include "SigaWin.ch"
#INCLUDE "protheus.ch"
#include "topconn.ch"
#INCLUDE "COLORS.CH"
#INCLUDE "FONT.CH"

/**  MT010CAN - Ponto de entrada  localizado nas funçőes  A010Inclui (Inclusăo do Produto),
	A010Altera (Alteraçăo do Produto) e A010Deleta (Deleçăo do Produto).
	Pode ser utilizado para executar customizaçőes conforme o tipo de retorno: Execuçăo OK
	ou Execuçăo Cancelada.
**/
//26/09/2019 - Luís Gustavo - Adequaçăo para release 12.1.25
User Function MT010CAN()
     If FWCodEmp() == '11' //Empresas que săo do grupo 11(Tecpolpa).
        //Chama rotina Chaus  para executar as funcoes apos a inclusao ou alteracao do produto
        If SUPERGETMV("CF_ATIVARP", .F. , .F.)
           U_CHROTP03()
        Endif
     Endif
Return Nil
