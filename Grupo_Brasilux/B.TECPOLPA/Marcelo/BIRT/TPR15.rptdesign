                </structure>
                <structure>
                    <property name="position">6</property>
                    <property name="name">QTD_INS_NO_TA</property>
                    <property name="nativeName">QTD_INS_NO_TA</property>
                    <property name="dataType">float</property>
                    <property name="nativeDataType">8</property>
                </structure>
                <structure>
                    <property name="position">7</property>
                    <property name="name">B2_QATU</property>
                    <property name="nativeName">B2_QATU</property>
                    <property name="dataType">float</property>
                    <property name="nativeDataType">8</property>
                </structure>
                <structure>
                    <property name="position">8</property>
                    <property name="name">SALDO_TER_CALC</property>
                    <property name="nativeName">SALDO_TER_CALC</property>
                    <property name="dataType">float</property>
                    <property name="nativeDataType">8</property>
                </structure>
