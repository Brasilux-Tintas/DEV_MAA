                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">11</property>
                    <property name="name">HORA</property>
                    <property name="nativeName">HORA</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT *, B2_QATU +  QTD_INS_NO_TA AS SALDO_TER_CALC,  B2_QATU +  QTD_INS_NO_TA - B2_TER DIFERENCA,
CONVERT(VARCHAR(10), GETDATE(), 103) AS DATA, CONVERT(VARCHAR(10), GETDATE(), 108) AS HORA
FROM 
(SELECT	B1_COD COD_INS, SUBSTRING(B1_DESC,1,60) as 'DESCRIÇÃO',B1_TIPO,  B1_UM,
ISNULL((SELECT SUM(B2_QTNP + B2_QTER) FROM  SB2110 SB2 WHERE B2_COD = B1_COD  AND SB2.D_E_L_E_T_ = ''),0) B2_TER,
ISNULL(SUM(QTD_INS),0) QTD_INS_NO_TA ,
ISNULL((SELECT SUM(B2_QATU) FROM  SB2110 SB2 WHERE B2_COD = B1_COD  AND SB2.D_E_L_E_T_ = ''),0) B2_QATU
FROM	SB1110 SB1
LEFT JOIN INSUMOS_SB6 ON B1_COD = COD_INS AND COD_INS LIKE '4%'
WHERE	  SB1.D_E_L_E_T_ = '' AND B1_COD LIKE '4%' AND  B1_COD BETWEEN 	 ?  AND ?
AND  B1_TIPO BETWEEN ? AND  ?
GROUP BY B1_COD , B1_DESC, B1_TIPO, B1_UM)A
WHERE (B2_TER + QTD_INS_NO_TA + B2_QATU ) != 0
ORDER BY A.COD_INS]]></xml-property>
        </oda-data-set>
    </data-sets>
