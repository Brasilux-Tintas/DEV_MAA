User Function TECF005()
Local aArea := ZC6->(GetArea())
Private oBrowse

// Instanciamento da Classe de Browse 
oBrowse := FWMBrowse():New() 

// Defini鈬o da tabela do Browse 
oBrowse:SetAlias('ZC6') 

// Titulo da Browse 
oBrowse:SetDescription('Cadastros Refor輟 e Redu鈬o')
 
// Opcionalmente pode ser desligado a exibi鈬o dos detalhes 
oBrowse:DisableDetails() 

// isso pode n縊 apresentar o menu
//oBrowse:SetMenuDef( 'FSFATC01' )

oBrowse:Activate() 

RestArea(aArea)

Return


