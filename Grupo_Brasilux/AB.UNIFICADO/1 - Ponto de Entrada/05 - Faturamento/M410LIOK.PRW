#include "totvs.ch"

/*/{Protheus.doc} M410LIOK
//TODO Descriчуo auto-gerada.
@author gustavosouza
@since 23/09/2019
@version 1.0
@return ${return}, ${return_description}
@type function
/*/
User Function M410LIOK()
     Local _x      := 0
     Local cCodPro := ""
     Local nPosPro,lCanc 
     Local _lRet   := .T.
     Local _cMsg
   Local _cGrpEmp := alltrim(FWGrpCompany())
   If !(_cGrpEmp == '11')
        /*▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄
        ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
        ▒▒╔══════════╤══════════╦═══════╤════════════════════╦══════╤═════════════╗▒▒
        ▒▒║Programa  │ M410LIOK ║Autor  │ Cleber O. Domingues║ Data │  08/08/02   ║▒▒
        ▒▒╠══════════╪══════════╩═══════╧════════════════════╩══════╧═════════════╣▒▒
        ▒▒║Desc.     │ Verifica se o item jс estс digitado.                       ║▒▒
        ▒▒║ 18/08/05 │ Verifica se o item estс deletado se щ normal e se possui - ║▒▒
        ▒▒║          │ lote de produчуo cadastrado. Caso seja verdade nуo deixa - ║▒▒
        ▒▒║          │ deletar o item.                                            ║▒▒
        ▒▒╠══════════╪════════════════════════════════════════════════════════════╣▒▒
        ▒▒║Uso       │ Brasilux Tintas Tщcnicas Ltda.                             ║▒▒
        ▒▒╚══════════╧════════════════════════════════════════════════════════════╝▒▒
        ▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
        ▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀*/
      lCanc := .f. //Cancelar verificaчуo
      //Cleber(01/04/21) -> Exceчуo para clientes exportaчуo
      IF (M->C5_TIPO == 'N') .AND. (POSICIONE("SA1",1,xFilial("SA1")+M->C5_CLIENTE,"A1_EST") = "EX")
         lCanc := .t.
      ENDIF 
      IF !lCanc
         nPosPro := aScan(aHeader, {|x| Trim(x[2]) == "C6_PRODUTO"})
         If nPosPro > 0
            If !aCols[n][Len(aHeader)+1] .and. (M->C5_TIPO == 'N') .and. (M->C5_CLIENTE <> "023818") // Se nуo for Item deletado e pedido Normal e nуo for pedido para Dep. Fechado
               cCodPro := aCols[n][nPosPro]
               For _x := 1 To Len(aCols)
                  If (_x <> n) .and. (aCols[_x][nPosPro] == cCodPro) .and. !aCols[_x][Len(aHeader)+1]
                     _lRet = .f.
                     Exit
                  Endif
               Next
               If !_lRet
                  //LGS#20200114 - Ajuste na funчуo de mensagem
				      //MsgBox("Existe item em DUPLICIDADE!", "Atenчуo...", "ALERT")
                  _cMsg := "Item "+cCodPro+" em DUPLICIDADE!"
   				   MessageBox( _cMsg, "Atenчуo!", 48 )

               Endif
            Endif
         Endif
      ENDIF
   Else
        // Chama rotina da Chaus que valida se o produto/cliente/fornecedor teve o cadastro finalizado
        _lRet := u_CHROTG13()
        // se a tes controla terceiros exige o preenchimento do campo NUM OP TA
        If _lRet
           _lRet := valNumOP()
        Endif
   Endif
Return( _lRet )

Static Function valNumOP()
       //Local aArea      := GetArea()
       Local cAliaAnte  := Alias()
       Local nAreaAnte  := IndexOrd()
       Local nRegiAnte  := RecNo()
       //Local _nItem     := 0
       Local _lRet      := .T.
       Local _cProduto  := ACols[n,Ascan(aHeader,{|x| AllTrim(x[2]) == "C6_PRODUTO"})]
       Local _cNumOP    := ACols[n,Ascan(aHeader,{|x| AllTrim(x[2]) == "C6_XNUMOP"})]
       Local _tpMercado := Posicione( "SA1", 1, xFILIAL("SA1")+M->C5_CLIENTE +  M->C5_LOJACLI,"A1_XMERCAD" )
       Local _tpProduto := Posicione( "SB1", 1, xFILIAL("SB1")+_cProduto ,"B1_TIPO" )

       If _tpMercado == 'B' .AND. !ACOLS[N,LEN(ACOLS[N])] .AND. Empty(_cNumOP) .AND. !(_tpProduto $ "TA/PA") .AND. _cProduto != "1AAACFPPFE13"
          _lRet := .F.
          //LGS#20200114 - Ajuste na funчуo de mensagem
          //MsgBox("Dever ser preenchido o campo 'Num da Op TA' do item "+AllTrim(str(N)), "Atenчуo - MA410LIOK.prw", "ALERT")
          MessageBox( "Dever ser preenchido o campo 'Num da Op TA' do item " + AllTrim(str(N)), "Atenчуo - MA410LIOK.prw", 48 )
       Endif
       dbSelectArea(cAliaAnte)
       dbSetOrder(nAreaAnte)
       dbGoTo(nRegiAnte)
Return _lRet
