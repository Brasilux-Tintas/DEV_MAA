//30/09/2019 - Luэs Gustavo - Adequaчуo para release 12.1.25
User Function F070DSC()
     Local _cArea  := Alias()
     Local cQry
     Local cCodUsr := RetCodUsr()
     Local lAcsDsc := .f.

     If FWCodEmp() <> '11' //Empresas que nуo sуo do grupo 11(Tecpolpa).
        If Empty(RetSqlName("SZW"))
           Return(.t.)
        Endif
        If (PSWADMIN( cUsername, SubStr(cUsuario, 1, 6),cCodUsr) == 0)
           lAcsDsc := .t.
        Else
           cQry := "SELECT ZW_ACESSOS "
           cQry += "FROM "+RetSqlName("SZW")+" SZW WITH (NOLOCK) "
           cQry += "WHERE (ZW_FILIAL = '"+xFilial("SZW")+"') "
           cQry += "AND (ZW_ROTINA = 'FINA070') "
           cQry += "AND (ZW_USUARIO = '"+cCodUsr+"') "
           TCQuery cQry ALIAS "TCQZW" NEW

           DbSelectArea("TCQZW")
           If !Bof() .and. !Eof()
              lAcsDsc := Iif(SubStr(TCQZW->ZW_ACESSOS, 1, 1) == '*', .t., .f.)
           Endif
           DbSelectArea("TCQZW")
           DbCloseArea()
        Endif    

        If !empty(_cArea)
           DbSelectArea(_cArea)
        Endif 
     Else
        lAcsDsc := .T. //LGS#20191007 - Para Tecpolpa nуo hс o tratamento de desconto utilizado na Brasilux atщ essa data.
     Endif
Return( lAcsDsc )