            <xml-property name="queryText"><![CDATA[SELECT DISTINCT D2_FILIAL AS VFILIAL, D2_CLIENTE AS VCLIENTE, D2_COD AS CODIGO,
       RTRIM(Z1_DESCR)+' - '+RTRIM(B1_DESC)+' '+Z5_DESCR AS DESCRICAO, 
CASE WHEN SUBSTRING(B1_CODBAR,1,1)<> 'S' THEN RTRIM(B1_CODBAR) + dbo.DigVer(B1_CODBAR) ELSE 'CODIGO-SUBSTITUIDO' END AS 'CODBAR',
 B1_POSIPI AS NCM,B1_IPI AS IPI,
CASE WHEN B1_PICMRET > 0 THEN 'SIM' ELSE 'NAO' END AS SUBSTRIB, B1_PESO AS PESOLIQ, B1_PESBRU AS PESOBRUTO, 
dbo.DetVol(D2_FILIAL,D2_COD) AS 'VOLUME', SA1.A1_NOME AS NCLIENTE
FROM SD2010 SD2 WITH(NOLOCK)
LEFT OUTER JOIN SB1010 SB1 WITH(NOLOCK) ON (SB1.D_E_L_E_T_ <> '*') AND (D2_FILIAL = B1_FILIAL) AND (D2_COD = B1_COD)
LEFT OUTER JOIN SZ5010 SZ5 WITH(NOLOCK) ON (SZ5.D_E_L_E_T_ <> '*') AND (SUBSTRING(D2_COD,11,2) = Z5_EMB)
LEFT OUTER JOIN SZ1010 SZ1 WITH(NOLOCK) ON (SZ1.D_E_L_E_T_ <> '*') AND (SUBSTRING(D2_COD,4,2) = Z1_LINHA)
LEFT OUTER JOIN SA1010 SA1 WITH(NOLOCK) ON (SB1.D_E_L_E_T_ <> '*') AND (D2_CLIENTE = A1_COD) AND (A1_FILIAL = '')
WHERE (SD2.D_E_L_E_T_ <> '*') AND (LEN(B1_CODBAR) = 12)  AND D2_FILIAL = ? AND D2_CLIENTE = ? 
                              AND D2_COD   BETWEEN ? AND ?
                              AND D2_GRUPO BETWEEN('PA00') AND ('PA99')
ORDER BY VFILIAL, VCLIENTE, CODIGO

---- ROUND USEI PARA LIMITAR EM 4 CASAS DECIMAIS DOS PESOS LIQ E BRUTO.
---- ROUND(B1_PESO,4) AS PESOLIQ, ROUND(B1_PESBRU,4) AS PESOBRUTO
---- PARA FAZER ARREDONDAENTEO DOS PESOS EM 4 CASAS IR EM pROPERTY (DODA pE) CLICAR NO CAMPO EX: PESO LIQ OU BRUTO
---- CLICAR EM FORMAT nUMBER E COLOCAR O FORMA NO CASO AQUI 4 CASAS DECIMAIS]]></xml-property>
