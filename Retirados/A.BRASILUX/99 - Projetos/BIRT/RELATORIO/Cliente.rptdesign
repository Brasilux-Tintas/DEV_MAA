            <xml-property name="queryText"><![CDATA[SELECT DISTINCT D2_COD AS CODIGO,RTRIM(ISNULL(Z1_DESCR,''))+' - '+RTRIM(B1_DESC)+' '+ISNULL(Z5_DESCR,'') AS DESCRICAO,
CASE WHEN B1_MSBLQL = '1' THEN 'EM DESUSO' WHEN (B1_VEND = 'N') THEN 'NAO VENDIDO' ELSE RTRIM(B1_CODBAR)+dbo.DigVer(B1_CODBAR) END AS CODBARRA ,
Z1_VALIDAD AS VALIDADE, B1_POSIPI AS NCM,B1_IPI AS IPI,
CASE WHEN B1_PICMRET > 0 THEN 'SIM' ELSE 'NAO' END AS SUBSTRIB,B1_PESO AS PESOLIQ,B1_PESBRU AS PESOBRUTO,dbo.DetVol(D2_FILIAL,D2_COD) AS RELVOL FROM SD2010 SD2
LEFT OUTER JOIN SB1010 SB1 ON (SB1.D_E_L_E_T_ <> '*') AND (D2_FILIAL = B1_FILIAL) AND (D2_COD = B1_COD)
LEFT OUTER JOIN SZ5010 SZ5 ON (SZ5.D_E_L_E_T_ <> '*') AND (SUBSTRING(D2_COD,11,2) = Z5_EMB)
LEFT OUTER JOIN SZ1010 SZ1 ON (SZ1.D_E_L_E_T_ <> '*') AND (SUBSTRING(D2_COD,4,2) = Z1_LINHA)
WHERE (SD2.D_E_L_E_T_ <> '*') AND (LEN(B1_CODBAR) = 12) AND (D2_CLIENTE = ?) 
ORDER BY CODIGO]]></xml-property>
