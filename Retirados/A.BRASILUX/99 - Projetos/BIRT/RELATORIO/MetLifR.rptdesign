            <xml-property name="queryText"><![CDATA[DECLARE @Empresa integer
set @Empresa = ?

IF(@Empresa = 11)
SELECT 
    CASE WHEN MONTH(GETDATE()) = 1 THEN CONVERT(VARCHAR(2), 12)+'/'+CONVERT(VARCHAR(4), YEAR(GETDATE())-1) ELSE CONVERT(VARCHAR(2), MONTH(GETDATE())-1)+'/'+CONVERT(VARCHAR(4), YEAR(GETDATE())) END,
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  1 THEN '00000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE  
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  2 THEN '0000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  3 THEN '000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  4 THEN '00000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  5 THEN '0000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  6 THEN '000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  7 THEN '00'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  8 THEN '0'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)
    END END END END END END END END,
    SRA.RA_NOME,
    CASE WHEN SRA.RA_CATFUNC = 'P' THEN '00000005500000' ELSE '00000005500000' END,
    CASE WHEN SRA.RA_SITFOLH IN('', 'F') THEN '1' ELSE '3' END,
    SUBSTRING(SRA.RA_NASC, 7, 2)+'/'+SUBSTRING(SRA.RA_NASC, 5, 2)+'/'+SUBSTRING(SRA.RA_NASC, 1, 4),
    SRA.RA_CIC,
    SRA.RA_SEXO,
    SUBSTRING(SRA.RA_ADMISSA, 7, 2)+'/'+SUBSTRING(SRA.RA_ADMISSA, 5, 2)+'/'+SUBSTRING(SRA.RA_ADMISSA, 1, 4) AS 'DT',
	m0_nomecom AS 'EMP COMPLETO' ,m0_cgc AS 'CNPJ'
	FROM SRA110 SRA
	LEFT OUTER JOIN sigamat sm WITH(NOLOCK) ON m0_codfil = '11' 
	WHERE SRA.D_E_L_E_T_ = ''
	AND SRA.RA_CATFUNC <>('A')
	AND SRA.RA_SITFOLH NOT IN('D')
	--AND SRA.RA_FILIAL =  @Empresa
	ORDER BY SRA.RA_FILIAL, SRA.RA_MAT
IF(@Empresa <> 11)
	SELECT 
    CASE WHEN MONTH(GETDATE()) = 1 THEN CONVERT(VARCHAR(2), 12)+'/'+CONVERT(VARCHAR(4), YEAR(GETDATE())-1) ELSE CONVERT(VARCHAR(2), MONTH(GETDATE())-1)+'/'+CONVERT(VARCHAR(4), YEAR(GETDATE())) END,
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  1 THEN '00000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE  
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  2 THEN '0000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  3 THEN '000000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  4 THEN '00000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  5 THEN '0000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  6 THEN '000'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  7 THEN '00'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    CASE WHEN LEN(SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)) =  8 THEN '0'+SRA.RA_FILIAL+RTRIM(SRA.RA_MAT) ELSE
    SRA.RA_FILIAL+RTRIM(SRA.RA_MAT)
    END END END END END END END END,
    SRA.RA_NOME,
    CASE WHEN SRA.RA_CATFUNC = 'P' THEN '00000005500000' ELSE '00000005500000' END,
    CASE WHEN SRA.RA_SITFOLH IN('', 'F') THEN '1' ELSE '3' END,
    SUBSTRING(SRA.RA_NASC, 7, 2)+'/'+SUBSTRING(SRA.RA_NASC, 5, 2)+'/'+SUBSTRING(SRA.RA_NASC, 1, 4),
    SRA.RA_CIC,
    SRA.RA_SEXO,
    SUBSTRING(SRA.RA_ADMISSA, 7, 2)+'/'+SUBSTRING(SRA.RA_ADMISSA, 5, 2)+'/'+SUBSTRING(SRA.RA_ADMISSA, 1, 4),
	m0_nomecom AS 'EMP COMPLETO' ,m0_cgc AS 'CNPJ'
	FROM SRA010 SRA
	LEFT OUTER JOIN sigamat sm WITH(NOLOCK) ON m0_codfil = @Empresa 
	WHERE SRA.D_E_L_E_T_ = ''
	AND SRA.RA_CATFUNC <>('A')
	AND SRA.RA_SITFOLH NOT IN('D')
	AND SRA.RA_FILIAL = @Empresa
	ORDER BY SRA.RA_FILIAL, SRA.RA_MAT
]]></xml-property>
