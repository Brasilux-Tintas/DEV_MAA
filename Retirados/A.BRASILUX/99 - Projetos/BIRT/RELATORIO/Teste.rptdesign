            <xml-property name="queryText"><![CDATA[SELECT

    'Quantidade (' + Rtrim(LTrim(SB1.B1_UM))  + ')'QTDUM1,

     CASE
			WHEN  SB1.B1_UM = 'LT' AND C2_XCONV <> 0  THEN C2_XCONV * C2_QUANT
          ELSE  NULL
     END    QTDKG,

     C2_XLOTE,
      '______________' CLINHA,
			NNR_DESCRI,
			CAST(SC2.C2_EMISSAO AS DATETIME) C2_EMISSAO,
			SC2.C2_FILIAL,
			SB1.B1_DESC DESC1,
			 SC2.C2_NUM,
			 SC2.C2_ITEM,
			 SC2.C2_SEQUEN,
			 SC2.C2_ITEMGRD,
			 SC2.C2_DATRF,
			 SC2.C2_PRODUTO,
			 SC2.C2_DESTINA,
			 SC2.C2_PEDIDO,
			 SC2.C2_ROTEIRO,
			 SC2.C2_QUJE,
			 SC2.C2_PERDA,
			 SC2.C2_QUANT,
			 C2_QUANT -C2_QUJE QTDLIQ,

			  SC2.C2_OBS,
			  SC2.C2_TPOP,
			 SC2.R_E_C_N_O_  SC2RECNO ,
			 D4_SEQ, D4_OP,
			 D4_LOCAL,
			 SB1.B1_UM UM1,
			 SB1_.B1_UM UM2,
			 SUBSTRING(SB1_.B1_DESC,1,30) DESC2,
			 D4_COD,
			 D4_QTDEORI,
			  '___/___/___' DT_BRANCO,
			    '___:___' HR_BRANCO,


			 CAST(SC2.C2_DATPRI AS DATETIME) C2_DATPRI,
			 CAST(SC2.C2_DATPRF AS DATETIME) C2_DATPRF,
			 SC2.C2_CC,

			CASE
				WHEN    SC2.C2_DATAJI = ' '  THEN '___/___/___'
				ELSE  SUBSTRING(C2_DATAJI, 7,2) +'/'+SUBSTRING(C2_DATAJI, 5,2) +'/'+ SUBSTRING(C2_DATAJI, 1,4)
			END C2_DATAJI	,

			CASE
				WHEN    SC2.C2_DATAJF = ' '  THEN '___/___/___'
				ELSE SUBSTRING(C2_DATAJF, 7,2) +'/'+SUBSTRING(C2_DATAJF, 5,2) +'/'+ SUBSTRING(C2_DATAJF, 1,4)
			END C2_DATAJF	,

			CASE
				WHEN C2_STATUS IN ( 'S') THEN 'Sacramentada'
				WHEN C2_STATUS IN ( 'U') THEN 'Suspensa'
				WHEN C2_STATUS IN ( 'N') THEN 'Normal'
			END C2_STATUS,
			D4_LOTECTL, D4_NUMLOTE




FROM SC2110 SC2
        INNER JOIN SB1110 SB1 ON B1_FILIAL = '11' AND C2_PRODUTO = B1_COD AND SB1.D_E_L_E_T_=' '
        INNER JOIN SD4110 SD4 ON D4_FILIAL = '11' AND C2_NUM+C2_ITEM+C2_SEQUEN+C2_ITEMGRD = D4_OP AND SD4.D_E_L_E_T_=' '
        INNER JOIN SB1110 SB1_ ON SB1_.B1_FILIAL = '11' AND D4_COD = SB1_.B1_COD AND SB1_.D_E_L_E_T_=' '
        LEFT JOIN NNR110 NNR ON NNR.NNR_FILIAL = '11' AND  NNR_CODIGO = D4_LOCAL AND NNR.D_E_L_E_T_=' '

WHERE  SC2.C2_FILIAL='11'
		AND SC2.D_E_L_E_T_=' '

		AND D4_OP BETWEEN 	'00422201001   ' AND 	'00422201003   '
		AND SC2.C2_DATPRF BETWEEN  '' AND 'ZZZZZZZZ'


ORDER BY SC2.C2_FILIAL, SC2.C2_DATPRF, D4_OP, SB1_.B1_COD]]></xml-property>
