            <xml-property name="queryText"><![CDATA[
SELECT CASE WHEN T10.TRX_FILIAL = '010101' THEN 'BRASILUX/MATRIZ'         WHEN T10.TRX_FILIAL = '010102' THEN 'BRASILUX/ESCRITÓRIO'
            WHEN T10.TRX_FILIAL = '010103' THEN 'BRASILUX/SÃO PAULO'      WHEN T10.TRX_FILIAL = '010104' THEN 'BRASILUX/RESINA' 
            WHEN T10.TRX_FILIAL = '010105' THEN 'BRASILUX/OBRA'           WHEN T10.TRX_FILIAL = '010106' THEN 'BRASILUX/DEPOSITO'
            WHEN T10.TRX_FILIAL = '010107' THEN 'BRASILUX/DEPOSITO MATÃO' WHEN T10.TRX_FILIAL = '060101'THEN 'DISSOLTEX' else 
       T10.TRX_FILIAL END AS 'VFILIAL', T10.TRX_PREFIX AS 'VPREFIX', T10.TRX_NUMSE2 AS 'VNUMSE2', T10.TRX_DTINFR AS 'VDTINFR',
       T10.TRX_RODOVI AS 'VRODOVI', T10.TRX_LOCAL  AS 'VLOCAL',  T10.TRX_CIDINF AS 'VCIDINF', T10.TRX_UFINF  AS 'VUFINF',
       T10.TRX_RHINFR AS 'VRHINFR', T10.TRX_NOME   AS 'VNOME',   T10.TRX_PLACA  AS 'VPLACA',  T10.TRX_TPMULT AS 'VTPMULT',
       T10.TRX_CODINF AS 'VCODINF', T10.TRX_VALOR  AS 'VVALOR',  T10.TRX_DESCON AS 'VDESCON', 
       (T10.TRX_VALOR - T10.TRX_DESCON) AS VVALLIQ,
       SUBSTRING(T10.TRX_DTINFR,7,2) + '/' + SUBSTRING(T10.TRX_DTINFR,5,2) + '/' + SUBSTRING(T10.TRX_DTINFR,1,4) AS 'VDINFR',
       SUBSTRING(SE2.E2_VENCTO,7,2)  + '/' + SUBSTRING(SE2.E2_VENCTO,5,2)  + '/' + SUBSTRING(SE2.E2_VENCTO,1,4)  AS 'VDVENC',
       SE2.E2_FILIAL, SE2.E2_VENCTO AS 'VVENCTO', SE2.E2_TIPO AS 'VTIPO', TSH.TSH_DESART AS 'VDESART'
FROM TRX010 T10 WITH(NOLOCK)
LEFT OUTER JOIN SE2010 SE2 WITH (NOLOCK) ON T10.TRX_FILIAL = SE2.E2_FILIAL AND SE2.D_E_L_E_T_<> '*' AND SE2.E2_NUM = T10.TRX_NUMSE2 AND
                              SE2.E2_PREFIXO = T10.TRX_PREFIX  
LEFT OUTER JOIN TSH010 TSH WITH (NOLOCK) ON T10.TRX_CODINF = TSH.TSH_CODINF AND TSH.D_E_L_E_T_ <> '*'
WHERE T10.TRX_DTINFR >= '20140101' AND T10.D_E_L_E_T_ <> '*' AND T10.TRX_FILIAL = ? 
                                                             AND T10.TRX_DTINFR BETWEEN ? AND ?  
Order By T10.TRX_FILIAL, T10.TRX_DTINFR


---- CASE WHEN CFD_FILIAL = '010101' THEN 'BRASILUX/MATRIZ' WHEN CFD_FILIAL = '060101' THEN 'DISSOLTEX']]></xml-property>
            <xml-property name="designerValues"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
