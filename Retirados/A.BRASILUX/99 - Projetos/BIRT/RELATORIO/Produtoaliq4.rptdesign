            <list-property name="resultSet">
                <structure>
                    <property name="position">1</property>
                    <property name="name">FILIAL</property>
                    <property name="nativeName">FILIAL</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">2</property>
                    <property name="name">CODPRO</property>
                    <property name="nativeName">CODPRO</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">3</property>
                    <property name="name">DESCRICAO</property>
                    <property name="nativeName">DESCRICAO</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
                <structure>
                    <property name="position">4</property>
                    <property name="name">PERVEN</property>
                    <property name="nativeName">PERVEN</property>
                    <property name="dataType">string</property>
                    <property name="nativeDataType">12</property>
                </structure>
            </list-property>
            <xml-property name="queryText"><![CDATA[SELECT CASE WHEN CFD_FILIAL = '010101' THEN 'BRASILUX/MATRIZ' WHEN CFD_FILIAL = '060101' THEN 'DISSOLTEX' 
  ELSE CFD_FILIAL END AS FILIAL,CFD_COD AS CODPRO,B1_DESC AS DESCRICAO, 
       SUBSTRING(CFD_PERVEN,1,2) + '/' + SUBSTRING(CFD_PERVEN,3,4) AS 'PERVEN'
  FROM CFD010 CFD 
LEFT OUTER JOIN SB1010 SB1 ON (SB1.D_E_L_E_T_ <> '*') AND (B1_FILIAL = CFD_FILIAL) AND (B1_COD = CFD_COD) 
WHERE (CFD.D_E_L_E_T_ <> '*') AND (CFD_PERVEN = ?) AND (CFD_CONIMP >= 40.0) AND (B1_X_SIM3G = 'S') ORDER BY FILIAL,CODPRO
]]></xml-property>
        </oda-data-set>
    </data-sets>
