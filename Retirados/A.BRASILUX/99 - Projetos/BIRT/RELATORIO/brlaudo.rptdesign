            <xml-property name="queryText"><![CDATA[WITH TMP AS(SELECT DISTINCT C5_FILIAL, C5_NUM, C5_CLIENT, A1_NOME, C6_PRODUTO, C6_DESCRI, ZZK_LOTE, C2_DATPRF, Z1_VALIDAD AS 'VALMESES', DATEADD(DAY,(Z1_VALIDAD *30), C2_DATPRF) AS 'DTVALIDADE'
FROM SC5010 SC5 WITH(NOLOCK)
LEFT OUTER JOIN SC6010 SC6 WITH(NOLOCK) ON C5_FILIAL  = C6_FILIAL AND C5_NUM = C6_NUM AND SC6.D_E_L_E_T_ =''
LEFT OUTER JOIN ZZK010 ZZK WITH(NOLOCK) ON ZZK_FILIAL = C6_FILIAL AND ZZK_PRODUT = C6_PRODUTO AND ZZK_PEDIDO = C6_NUM AND ZZK.D_E_L_E_T_ =''
LEFT OUTER JOIN SA1010 SA1 WITH(NOLOCK) ON A1_FILIAL  = '' AND A1_COD = C5_CLIENT AND SA1.D_E_L_E_T_ =''
LEFT OUTER JOIN SC2010 SC2 WITH(NOLOCK) ON C2_FILIAL  = ZZK_FILIAL AND C2_LOTE = ZZK_LOTE AND C2_PRODUTO = ZZK_PRODUT AND SC2.D_E_L_E_T_ =''
LEFT OUTER JOIN SZ1010 SZ1 WITH(NOLOCK) ON Z1_FILIAL  ='01' AND Z1_LINHA = SUBSTRING(C2_PRODUTO,4,2) AND SZ1.D_E_L_E_T_ =''
WHERE C5_FILIAL = ? AND C5_LAUDO ='S' AND SC5.D_E_L_E_T_ =''  AND C5_NUM = ? AND ZZK_LOTE = ?)
SELECT TMP.C5_NUM ,SUBSTRING(TMP.C6_PRODUTO,1,10) AS 'C6_PRODUTO',  TMP.C6_DESCRI,CONVERT (VARCHAR, TMP.DTVALIDADE, 103) AS 'DTVALIDADE' , TMP.C5_CLIENT, TMP.A1_NOME, QPR_LOTE, QPR_REVI,(SUBSTRING(QPR_DTENTR,7,2)+'/'+ SUBSTRING(QPR_DTENTR,5,2)+'/'+SUBSTRING(QPR_DTENTR,1,4)) AS QPR_DTENTR, QPR_ENSAIO, QP1_DESCPO,  (SUBSTRING(QPR_DTMEDI,7,2)+'/'+ SUBSTRING(QPR_DTMEDI,5,2)+'/'+SUBSTRING(QPR_DTMEDI,1,4)) AS QPR_DTMEDI,QPR_ENSR,QPR_OP,QPR_CHAVE,QPR_RESULT,ISNULL(QP7_SEQLAB,QP8_SEQLAB) AS SEQLAB, ISNULL(QP7_UNIMED,'') AS 'UNID.MED', ISNULL(QP7_NOMINA,QP8_TEXTO) AS 'PADRÃO' , ISNULL(QP7_LIE,'') AS 'MINIMO', ISNULL(QP7_LSE,'') AS 'MAXIMO', ISNULL(QPS_MEDICA,CASE WHEN QPR_RESULT = 'A' THEN 'APROVADO' 
ELSE CASE WHEN QPR_RESULT = 'R' THEN 'REPROVADO' ELSE '' END END) AS 'RESULT',
QPM_DESLAU, QPR_METODO
FROM TMP
LEFT OUTER JOIN QPR010 QPR WITH (NOLOCK) ON TMP.C5_FILIAL = QPR_FILIAL AND TMP.ZZK_LOTE = QPR_LOTE AND SUBSTRING(TMP.C6_PRODUTO,1,10) = SUBSTRING(QPR_PRODUT,1,10) AND QPR.D_E_L_E_T_ =''
LEFT OUTER JOIN QP7010 QP7 WITH(NOLOCK) ON QP7_FILIAL = QPR_FILIAL AND QP7_PRODUT = QPR_PRODUT AND QP7_REVI = QPR_REVI AND QPR_ENSAIO = QP7_ENSAIO AND  QP7.D_E_L_E_T_ =''
LEFT OUTER JOIN QP8010 QP8 WITH(NOLOCK) ON QP8_FILIAL = QPR_FILIAL AND QP8_PRODUT = QPR_PRODUT AND QP8_REVI = QPR_REVI AND QPR_ENSAIO = QP8_ENSAIO AND  QP8.D_E_L_E_T_ =''
LEFT OUTER JOIN QPM010 QPM WITH(NOLOCK) ON QPM_FILIAL = QPR_FILIAL AND QPM_PRODUT = QPR_PRODUT AND QPM_LOTE = QPR_LOTE AND QPM.D_E_L_E_T_ =''
LEFT OUTER JOIN QPS010 QPS WITH(NOLOCK) ON QPS_FILIAL = QPR_FILIAL AND QPS_CODMED = QPR_CHAVE AND QPS.D_E_L_E_T_ =''
LEFT OUTER JOIN QP1010 QP1 WITH(NOLOCK) ON QP1_FILIAL = QPR_FILIAL AND QP1_ENSAIO = QPR_ENSAIO AND QP1.D_E_L_E_T_ =''
WHERE QPR.D_E_L_E_T_ ='']]></xml-property>
